    {
      "id": "mos-excel-formulas-001",
      "version": "1.0",
      "exam": {
        "code": "mos-excel",
        "name": "MOS Excel Associate (MO-200)",
        "vendor": "Microsoft",
        "year": 2026
      },
      "domain": {
        "id": "formulas",
        "name": "数式・関数の利用",
        "weight_percent": 25
      },
      "topic": "絶対参照",
      "subtopic": "$ 記号の意味",
      "cognitive_level": "L2-Understand",
      "difficulty": "easy",
      "stem": "セル B2 に式 `=A2*$C$1` を入力し、B3〜B10 にコピー（オートフィル）した。B5 にコピーされた式はどうなるか？",
      "options": [
        {
          "id": "A",
          "text": "=A5*$C$1",
          "is_correct": true,
          "explanation": "正解。A2 は相対参照なのでコピー先で A5 にずれ、$C$1 は絶対参照なのでそのまま固定される。"
        },
        {
          "id": "B",
          "text": "=A2*$C$1",
          "is_correct": false,
          "explanation": "両方とも変わらないのは、すべて絶対参照（$A$2*$C$1）の場合。A2 は相対参照なので変化する。"
        },
        {
          "id": "C",
          "text": "=A5*$C$4",
          "is_correct": false,
          "explanation": "$C$1 は完全絶対参照（行も列も $）のため、行方向のコピーでも C1 のまま動かない。"
        },
        {
          "id": "D",
          "text": "=$A$5*$C$1",
          "is_correct": false,
          "explanation": "A2 は $ なしの相対参照なので A5 となるが、$ は付かない。"
        }
      ],
      "explanation": "$ 記号は「コピー時に変えない」という固定指示。$A$1 は完全絶対（行列とも固定）、A$1 は行のみ固定、$A1 は列のみ固定、A1 は完全相対。F4 キーで4状態（A1 → $A$1 → A$1 → $A1 → A1）を循環できる。MOS Associate 最頻出概念。",
      "references": [
        {
          "title": "絶対参照と相対参照を切り替える",
          "url": "https://support.microsoft.com/ja-jp/office/数式の相対参照-絶対参照-複合参照を切り替える-dfec08cd-ae65-4f56-839e-5f0d8d0baca9"
        }
      ],
      "tags": [
        "absolute-reference",
        "relative-reference",
        "dollar-sign",
        "f4",
        "fill"
      ],
      "common_mistakes": [
        "$ の意味を「お金関連」と勘違い",
        "$A$1 と A$1 の違いを理解していない",
        "F4 の循環を知らずに毎回手入力"
      ],
