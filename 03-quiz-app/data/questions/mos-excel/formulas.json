    {
      "id": "mos-excel-formulas-003",
      "version": "1.0",
      "exam": {
        "code": "mos-excel",
        "name": "MOS Excel Associate (MO-200)",
        "vendor": "Microsoft",
        "year": 2026
      },
      "domain": {
        "id": "formulas",
        "name": "数式・関数の利用",
        "weight_percent": 25
      },
      "topic": "VLOOKUP / XLOOKUP",
      "subtopic": "近似一致と完全一致",
      "cognitive_level": "L4-Analyze",
      "difficulty": "medium",
      "stem": "ある FinTech 企業の担当者が =VLOOKUP(A2, 商品マスタ!A:C, 3, TRUE) と書いたところ、商品コードが完全一致しないのに別商品の値が返ってしまった。原因として最も適切なものは？",
      "options": [
        {
          "id": "A",
          "text": "第4引数を TRUE（近似一致）にしたため、ソート済みでない範囲で誤った結果が返った。FALSE（または 0）にすべき",
          "is_correct": true,
          "explanation": "正解。TRUE は範囲が昇順ソートされている前提の近似一致モード。コードのような完全一致が必要な場合は FALSE を指定する。"
        },
        {
          "id": "B",
          "text": "VLOOKUP は左端列でしか検索できないため、必ず INDEX/MATCH を使うべき",
          "is_correct": false,
          "explanation": "左端列の制約は事実だが、本問の検索は1列目（A列）で行っており該当しない。原因は第4引数。"
        },
        {
          "id": "C",
          "text": "範囲が A:C と列全体になっているため計算が遅く、結果が不正確になる",
          "is_correct": false,
          "explanation": "列全体指定は遅くなる可能性があるが、結果が不正確になる原因にはならない。"
        },
        {
          "id": "D",
          "text": "Excel の VLOOKUP は廃止されており、XLOOKUP しか使えない",
          "is_correct": false,
          "explanation": "VLOOKUP は廃止されておらず、現行 Excel でも利用可能。"
        }
      ],
      "explanation": "VLOOKUP の第4引数は最も誤りやすいポイント: TRUE/省略 = 近似一致（範囲は昇順前提）、FALSE/0 = 完全一致。コード・ID 系は必ず FALSE。XLOOKUP は既定で完全一致なのでより安全。VLOOKUP では「左端列以外を検索できない」「列番号で指定するため列追加に弱い」などの制約があり、Microsoft も新規には XLOOKUP を推奨している。",
      "references": [
        {
          "title": "VLOOKUP 関数",
          "url": "https://support.microsoft.com/ja-jp/office/vlookup-関数-0bbc8083-26fe-4963-8ab8-93a18ad188a1"
        },
        {
          "title": "XLOOKUP 関数",
          "url": "https://support.microsoft.com/ja-jp/office/xlookup-関数-b7fd680e-6d10-43e6-84f9-088b007cc9e4"
        }
      ],
      "tags": [
        "vlookup",
        "xlookup",
        "exact-match",
        "approximate-match",
        "lookup"
      ],
      "common_mistakes": [
        "TRUE と FALSE の意味を逆に覚える",
        "近似一致でソート前提を忘れる",
        "XLOOKUP の既定が完全一致と知らない"
      ],
      "quality_score": {
        "stem_clarity": 5,
        "distractor_plausibility": 5,
        "cognitive_level_match": 5,
        "explanation_completeness": 5,
        "overall": 5.0
      },
